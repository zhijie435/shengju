# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
MAIN_DB_NAME=question_management_shared
# 人才网库（按批次从企业导入时从此库读 sj_exam_imported_candidates；与主库同 host/user/password）
SHENGJU_DB_NAME=shengju

# JWT密钥（生产环境请务必修改）
JWT_SECRET=change-this-secret-in-production

# 服务器配置（若 3000 被占用可改为 3001、3002 等，改后需在各前端 .env 中设置 VITE_API_PORT=同一端口）
PORT=3000
NODE_ENV=development

# 经 Nginx/SLB 反代时保持默认即可（已默认 trust 第一层代理）。仅纯本机直连且仍报错时可设 TRUST_PROXY=0
# TRUST_PROXY=1

# 本地无用户时登录会尝试人才网企业接口；未部署人才网时请忽略日志里的 ECONNREFUSED，或改为实际地址
# TALENT_NETWORK_API_URL=http://127.0.0.1:3001

# DeepSeek AI配置（用于生成评估报告）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 阿里云短信（AccessKey、签名、模板等见 backend/services/aliyunSms.js 注释）
# 同一号码每小时最多「成功发出」验证码条数（默认 4，略低于阿里云常见验证码流控，减少 BUSINESS_LIMIT_CONTROL）
# SMS_MAX_SENDS_PER_PHONE_PER_HOUR=4
