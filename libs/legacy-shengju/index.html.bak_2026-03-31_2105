        // 带超时的fetch封装
        function fetchWithTimeout(url, options = {}, timeout = 5000) {
            return Promise.race([
                fetch(url, options),
                new Promise((_, reject) =>
                    setTimeout(() => reject(new Error('Request timeout')), timeout)
                )
            ]);
        }
        
        // 页面加载时检查后端服务（优化版本：优先使用CORS模式，可读取响应验证）
        async function checkBackendHealth(retryCount = 0) {
            // 如果正在检查且不是重试，等待当前检查完成
            if (backendStatus.checking && retryCount === 0) {
                let waitCount = 0;
                while (backendStatus.checking && waitCount < 30) {
                    await new Promise(resolve => setTimeout(resolve, 100));
                    waitCount++;
                }
                if (waitCount >= 30) {
                    console.warn('健康检查等待超时，返回当前状态');
                }
                return backendStatus;
            }
            
            backendStatus.checking = true;
            console.log(`[后端服务检测] 开始检测 (重试次数: ${retryCount})...`);
            
            // 尝试多个URL和端口（与后端路由一致：/api/v1/health），优先使用当前访问来源
            const healthPath = '/api/v1/health';
            const testUrls = [
                BACKEND_BASE_URL + healthPath,
                'http://127.0.0.1:3001' + healthPath,
                'http://localhost:3001' + healthPath,
                'http://127.0.0.1:3000' + healthPath,
                'http://localhost:3000' + healthPath
            ];
            
            // 方法1: 优先使用CORS模式检测（可以读取响应验证，最可靠）
            for (const url of testUrls) {
                try {
                    console.log(`[后端服务检测] 尝试CORS模式: ${url}`);
                    const response = await fetchWithTimeout(url, { 
                        method: 'GET',
                        mode: 'cors',
                        cache: 'no-cache',
                        credentials: 'omit'
                    }, 5000); // 5秒超时
                    
                    if (response && response.ok) {
                        // 验证响应内容，确保返回正确的JSON格式
                        try {
                            const data = await response.json();
                            if (data && (data.success === true || data.message)) {
                                const baseUrl = url.replace(/\/api\/v1\/health$/, '');
                                backendStatus.available = true;
                                backendStatus.checked = true;
                                backendStatus.baseUrl = baseUrl;
                                backendStatus.checking = false;
                                backendStatus.lastCheckTime = Date.now();
                                console.log('✅ 后端服务检测成功（CORS模式，已验证响应）:', baseUrl);
                                return backendStatus;
                            }
                        } catch (jsonError) {
                            console.warn(`[后端服务检测] ${url} 响应不是有效的JSON，继续尝试...`);
                            // 即使JSON解析失败，如果状态码是200，也认为服务在运行
                            const baseUrl = url.replace(/\/api\/v1\/health$/, '');
                            backendStatus.available = true;
                            backendStatus.checked = true;
                            backendStatus.baseUrl = baseUrl;
                            backendStatus.checking = false;
                            backendStatus.lastCheckTime = Date.now();
                            console.log('✅ 后端服务检测成功（CORS模式，状态码200）:', baseUrl);
                            return backendStatus;
                        }
                    }
                } catch (error) {
                    console.debug(`[后端服务检测] CORS模式失败 ${url}:`, error.message);
                    // 继续尝试下一个URL
                }
            }
            
            // 方法2: 如果CORS模式失败，尝试no-cors模式（作为备用方案）
            console.log('[后端服务检测] CORS模式全部失败，尝试no-cors模式...');
            for (const url of testUrls) {
                try {
                    console.log(`[后端服务检测] 尝试no-cors模式: ${url}`);
                    const response = await fetch(url, { 
                        method: 'GET',
                        mode: 'no-cors',
                        cache: 'no-cache'
                    });
                    // no-cors模式下能发送请求就说明服务在运行（但无法验证响应）
                    const baseUrl = url.replace(/\/api\/v1\/health$/, '');
                    backendStatus.available = true;
                    backendStatus.checked = true;
                    backendStatus.baseUrl = baseUrl;
                    backendStatus.checking = false;
                    backendStatus.lastCheckTime = Date.now();
                    console.log('⚠️ 后端服务检测成功（no-cors模式，未验证响应）:', baseUrl);
                    return backendStatus;
                } catch (error) {
                    console.debug(`[后端服务检测] no-cors模式失败 ${url}:`, error.message);
                    // 继续尝试
                }
            }
            
            // 如果所有方法都失败，且重试次数未达到上限，进行重试
            if (retryCount < 1) {
                console.log('[后端服务检测] 所有检测方法失败，500ms后重试...');
                backendStatus.checking = false;
                await new Promise(resolve => setTimeout(resolve, 500));
                return checkBackendHealth(retryCount + 1);
            }
            
            // 所有方法都失败
            backendStatus.available = false;
            backendStatus.checked = true;
            backendStatus.checking = false;
            backendStatus.lastCheckTime = Date.now();
            console.warn('❌ 后端服务检测失败：所有URL和检测方法都失败');
            return backendStatus;
        }
        
        // 页面加载时检查后端服务（简化版本，不显示警告）
        document.addEventListener('DOMContentLoaded', () => {
