        // 检查登录状态后进入相应页面（未登录时跳转到对应端登录页，不在首页弹窗登录）
        function checkAuthBeforeEnter(targetType) {
            var auth = (typeof AuthHelper !== 'undefined') ? AuthHelper.get(targetType) : null;
            if (!auth) auth = (localStorage.getItem('userType') === targetType) ? { token: localStorage.getItem('authToken'), userType: targetType } : null;
            if (!auth || !auth.token) {
                if (targetType === 'jobseeker') {
                    window.location.href = 'user/login.html';
                } else if (targetType === 'enterprise') {
                    window.location.href = 'enterprise/login.html';
                }
                return;
            }
            if (targetType === 'jobseeker') {
                window.location.href = 'user/index.html';
            } else if (targetType === 'enterprise') {
                window.location.href = 'enterprise/company-center.html';
            }
        }

        // 处理管理者登录（优先调用后端 API 获取真实 JWT，以便系统设置等接口可用）
        async function handleAdminLogin(event) {
            event.preventDefault();
            
            const username = document.getElementById('adminUsername').value.trim();
            const password = document.getElementById('adminPassword').value.trim();
            
            if (!username || !password) {
                showToast('请输入用户名和密码', 'error');
                return;
            }
            
            const apiBase = (typeof backendStatus !== 'undefined' && backendStatus.available && backendStatus.baseUrl)
                ? backendStatus.baseUrl + '/api/v1'
                : API_BASE_URL;
            
            try {
                // 优先调用后端登录接口，获取真实 JWT（系统设置等管理接口需要）
                const loginUrl = apiBase + '/auth/login';
                const res = await fetch(loginUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        identifier: username,
                        password: password,
                        userType: 'admin'
                    })
                });
                let result = null;
                try { result = await res.json(); } catch (_) {}
                if (res.ok && result && result.success && result.data && (result.data.token || result.data.accessToken)) {
