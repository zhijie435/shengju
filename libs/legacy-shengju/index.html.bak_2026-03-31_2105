        }

        // 更新测试账号提示
        function updateTestAccountHint() {
            const userTypeRadios = document.querySelectorAll('input[name="userType"]');
            const hintDiv = document.getElementById('testAccountHint');
            const hintList = document.getElementById('testAccountList');
            
            if (!hintDiv || !hintList) {
                console.warn('测试账号提示元素未找到');
                return;
            }
            
            // 找到选中的用户类型
            let selectedType = 'jobseeker';
            userTypeRadios.forEach(radio => {
                if (radio.checked) {
                    selectedType = radio.value;
                }
            });
            
            // 根据用户类型显示测试账号
            if (typeof TEST_ACCOUNTS !== 'undefined' && TEST_ACCOUNTS[selectedType]) {
                const accounts = TEST_ACCOUNTS[selectedType];
                hintList.innerHTML = '';
                
                accounts.forEach(account => {
                    const li = document.createElement('li');
                    const identifier = account.identifier || account.username || account.phone || '';
                    const password = account.password || '';
                    const displayName = account.username || account.displayName || identifier.split('@')[0] || identifier;
                    
                    if (selectedType === 'enterprise') {
                        const companyName = account.companyName ? ` - ${account.companyName}` : '';
                        li.innerHTML = `• ${identifier} / ${password} (${displayName}${companyName})`;
                    } else if (selectedType === 'jobseeker') {
                        li.innerHTML = `• ${identifier} / ${password} (${displayName})`;
                    } else {
                        li.innerHTML = `• ${identifier} / ${password}`;
                    }
                    hintList.appendChild(li);
