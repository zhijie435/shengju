        // 登录API（默认使用真实API，失败时回退到模拟登录）
        async function mockLogin(identifier, password, userType) {
            // 优化：快速检测后端服务状态（减少延迟）
            const now = Date.now();
            const lastCheck = backendStatus.lastCheckTime || 0;
            const shouldRecheck = !backendStatus.checked || (now - lastCheck > 60000) || !backendStatus.available;
            
            // 如果最近检测过且可用，直接使用（不重新检测）
            if (!shouldRecheck && backendStatus.available) {
                console.log('[登录] 使用缓存的后端服务状态:', backendStatus.baseUrl);
            } else {
                // 快速检测：只检测当前访问来源地址，超时时间短（500ms），路径与后端一致
                const healthCheckUrl = BACKEND_BASE_URL + '/api/v1/health';
                try {
                    const response = await fetchWithTimeout(healthCheckUrl, {
                        method: 'GET',
                        mode: 'cors',
                        cache: 'no-cache',
                        credentials: 'omit'
                    }, 500); // 优化：500ms超时，快速失败
                    
                    if (response && response.ok) {
                        backendStatus.available = true;
                        backendStatus.baseUrl = BACKEND_BASE_URL;
                        backendStatus.checked = true;
                        backendStatus.lastCheckTime = Date.now();
                        console.log('✅ [登录] 后端服务运行正常');
                    } else {
                        backendStatus.available = false;
                        backendStatus.checked = true;
                    }
                } catch (error) {
                    // 快速失败，使用模拟登录
                    backendStatus.available = false;
                    backendStatus.checked = true;
                }
            }
            
            const status = backendStatus;
            const apiBaseUrl = status.available ? `${status.baseUrl}/api/v1` : API_BASE_URL;
            
            // 如果后端服务不可用，直接尝试多个可能的URL
            const loginUrls = status.available 
                ? [`${apiBaseUrl}/auth/login`]
                : [
                    BACKEND_BASE_URL + '/api/v1/auth/login',
                    'http://localhost:3001/api/v1/auth/login',
                    'http://127.0.0.1:3001/api/v1/auth/login',
                    'http://localhost:3000/api/v1/auth/login',
                    'http://127.0.0.1:3000/api/v1/auth/login'
                ];
            
            // 首先尝试调用真实API
            let lastError = null;
            for (const loginUrl of loginUrls) {
                try {
                    const response = await fetchWithTimeout(loginUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        mode: 'cors',
                        cache: 'no-cache',
                        body: JSON.stringify({
                            identifier: identifier,
                            password: password,
                            userType: userType
                        })
                    }, 2000); // 优化：2秒超时，快速失败

                    if (response.ok) {
                        const result = await response.json();
                        if (result.success && result.data) {
                            // 真实API登录成功，更新后端服务状态
                            const baseUrl = loginUrl.replace('/api/v1/auth/login', '');
                            backendStatus.available = true;
                            backendStatus.baseUrl = baseUrl;
                            console.log('✅ 登录成功，后端服务地址:', baseUrl);
                            
                            return {
                                success: true,
                                token: result.data.accessToken || result.data.token,
                                refreshToken: result.data.refreshToken,
                                userId: result.data.userId,
                                username: result.data.username,
                                userType: result.data.userType,
                                email: result.data.email
                            };
                        } else {
                            // API返回了响应，但登录失败（如账号密码错误）
                            throw new Error(result.message || '登录失败');
                        }
                    } else {
                        // HTTP错误（如400, 401, 500等），说明后端服务在运行
                        const errorData = await response.json().catch(() => ({}));
                        const errorMessage = errorData.message || `HTTP ${response.status}`;
                        
                        // 更新后端服务状态为可用（因为收到了HTTP响应）
                        const baseUrl = loginUrl.replace('/api/v1/auth/login', '');
                        backendStatus.available = true;
                        backendStatus.baseUrl = baseUrl;
                        console.log('⚠️ 后端服务运行正常，但登录失败:', errorMessage);
                        
                        // 抛出业务错误，不是连接错误
                        throw new Error(errorMessage);
                    }
                } catch (apiError) {
                    lastError = apiError;
                    // 继续尝试下一个URL
                    console.debug('登录尝试失败:', loginUrl, apiError.message);
                    continue;
                }
            }
            
            // 所有URL都失败，使用最后一个错误
            const apiError = lastError || new Error('无法连接到服务器');
            
            // 检查是否是真正的连接错误（没有收到HTTP响应）
            const isConnectionError = (
                apiError.message.includes('Failed to fetch') || 
                apiError.message.includes('NetworkError') ||
                apiError.message.includes('ERR_CONNECTION_REFUSED') ||
                (apiError.name === 'TypeError' && apiError.message.includes('fetch')) ||
                apiError.message.includes('timeout') ||
                apiError.message.includes('Request timeout')
            ) && !apiError.message.includes('HTTP'); // 如果包含HTTP状态码，说明收到了响应，不是连接错误
            
            console.log('登录API调用失败:', {
                error: apiError.message,
                errorName: apiError.name,
                isConnectionError: isConnectionError,
                backendAvailable: backendStatus.available,
                backendBaseUrl: backendStatus.baseUrl
            });
            
            // 如果错误信息包含HTTP状态码（如"HTTP 500"、"用户不存在"等），说明后端服务在运行
            // 但如果是"用户不存在"或"密码错误"，可能是真实API中没有该账号，尝试模拟登录
            const isBusinessError = apiError.message.includes('HTTP') || 
                apiError.message.includes('用户不存在') ||
                apiError.message.includes('密码错误') ||
                apiError.message.includes('用户已被禁用') ||
                apiError.message.includes('邮箱和密码不能为空');
            
            if (isBusinessError) {
                // 这是业务错误，后端服务在运行
                console.log('✅ 后端服务运行正常，这是业务错误:', apiError.message);
                // 更新后端服务状态
                backendStatus.available = true;
                backendStatus.baseUrl = backendStatus.baseUrl || BACKEND_BASE_URL;
                
                // 如果是"用户不存在"或"密码错误"或"账号或密码错误"，尝试使用模拟账号登录
                if (apiError.message.includes('用户不存在') || apiError.message.includes('密码错误') || apiError.message.includes('账号或密码错误')) {
                    console.log('[登录] 真实API中账号不存在或密码错误，尝试模拟账号登录...');
                    // 回退到模拟登录
                    return new Promise((resolve) => {
                        setTimeout(() => {
                            try {
                                // 使用测试账号验证
                                const account = findTestAccount(identifier, password, userType);
                                
                                if (account) {
                                    console.log('✅ [登录] 模拟账号登录成功:', account.username || account.identifier);
                                    resolve({
                                        success: true,
                                        token: 'mock_token_' + Date.now(),
                                        refreshToken: 'mock_refresh_' + Date.now(),
                                        userId: 'mock_' + Date.now(),
                                        username: account.username || account.displayName || identifier.split('@')[0] || identifier,
                                        userType: userType,
                                        email: account.identifier || account.email || identifier
                                    });
                                } else {
                                    // 模拟账号也不存在，抛出原始错误
                                    resolve({
                                        success: false,
                                        message: apiError.message
                                    });
                                }
                            } catch (error) {
                                console.error('模拟登录错误:', error);
                                resolve({
                                    success: false,
                                    message: apiError.message
                                });
                            }
                        }, 50); // 优化：减少延迟到50ms
                    });
                } else {
                    // 其他业务错误（如用户已被禁用），直接抛出
                    throw apiError;
                }
            }
            
            // 如果是连接错误，回退到模拟登录
            if (isConnectionError) {
                console.log('[登录] 检测到连接错误，回退到模拟登录...');
                
                // 回退到模拟登录（用于开发/测试）- 优化：立即执行，无延迟
                try {
                    // 使用测试账号验证
                    const account = findTestAccount(identifier, password, userType);
                    
                    if (account) {
                        console.log('✅ [登录] 模拟账号登录成功（后端服务不可用）:', account.username || account.identifier);
                        return {
                            success: true,
                            token: 'mock_token_' + Date.now(),
                            refreshToken: 'mock_refresh_' + Date.now(),
                            userId: 'mock_' + Date.now(),
                            username: account.username || account.displayName || identifier.split('@')[0] || identifier,
                            userType: userType,
                            email: account.identifier || account.email || identifier
                        };
                    } else {
                        // 提供更详细的错误信息
                        let errorMessage = '用户名或密码错误';
                        if (typeof TEST_ACCOUNTS !== 'undefined' && TEST_ACCOUNTS[userType]) {
                            const accounts = TEST_ACCOUNTS[userType];
                            const foundById = accounts.find(acc => 
                                acc.identifier && acc.identifier.toLowerCase() === identifier.toLowerCase() ||
                                acc.phone === identifier ||
                                acc.username && acc.username.toLowerCase() === identifier.toLowerCase()
                            );
                            if (foundById && foundById.password !== password) {
                                errorMessage = '密码错误';
                            } else if (!foundById) {
                                errorMessage = '账号不存在，请检查邮箱/手机号/用户名';
                            }
                        }
                        return {
                            success: false,
                            message: errorMessage + '\n\n提示：后端服务不可用，请确保后端服务已启动'
                        };
                    }
                } catch (error) {
                    console.error('模拟登录错误:', error);
                    return {
                        success: false,
                        message: '登录失败: ' + error.message
                    };
                }
            }
            
            // 其他类型的错误，直接抛出
            throw apiError;
        }

        // 注册API（默认使用真实API，失败时回退到模拟注册）
        async function mockRegister(username, email, phone, password, verifyCode, userType) {
            // 首先尝试调用真实API
            try {
                // 暂不使用企业端短信验证码，不校验验证码

                var registerBaseUrl = (typeof backendStatus !== 'undefined' && backendStatus.baseUrl)
                    ? (backendStatus.baseUrl + '/api/v1') : API_BASE_URL;
                const response = await fetch(registerBaseUrl + '/auth/register', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        username: username,
                        email: email,
                        phone: phone,
                        password: password,
                        userType: userType
                    })
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success && result.data) {
                        // 真实API注册成功
                        return {
                            success: true,
                            message: '注册成功',
                            data: {
                                userId: result.data.userId,
                                username: result.data.username,
                                email: result.data.email,
                                userType: result.data.userType,
                                token: result.data.accessToken || result.data.token,
                                refreshToken: result.data.refreshToken
                            }
                        };
                    } else {
                        throw new Error(result.message || '注册失败');
                    }
                } else {
                    const errorData = await response.json().catch(() => ({}));
                    throw new Error(errorData.message || `HTTP ${response.status}`);
                }
            } catch (apiError) {
                var isConnectionError = apiError.message && (
                    apiError.message.includes('Failed to fetch') ||
                    apiError.message.includes('NetworkError') ||
                    apiError.message.includes('ERR_CONNECTION_REFUSED') ||
                    apiError.message.includes('timeout') ||
                    apiError.message.includes('Request timeout')
                );
                if (isConnectionError) {
                    console.warn('真实API注册失败（后端未连接）:', apiError.message, '- 请先运行「启动服务.bat」或「backend/启动后端服务.bat」');
                } else {
                    console.warn('真实API注册失败:', apiError.message);
                }
                // 连接类错误：不落库，直接提示用户
                if (isConnectionError) {
                    return {
                        success: false,
                        message: '无法连接后端服务，注册数据未保存，请启动后端服务后重试'
                    };
                }
                // 业务错误（如邮箱已注册）返回失败信息
                return {
                    success: false,
                    message: apiError.message || '注册失败，请稍后重试'
                };
            }
        }

        // 模拟第三方登录API
        async function mockThirdPartyLogin(platform, accountInfo, loginType, userType = 'jobseeker') {
            return new Promise((resolve) => {
                setTimeout(() => {
                    // 模拟登录逻辑
                    // 这里模拟：如果账号不存在，需要注册
                    const needRegister = Math.random() > 0.5; // 50%概率需要注册
                    
                    // 根据平台生成不同的用户信息
                    const platformUserInfo = {
                        wechat: {
                            nickname: '微信用户',
                            defaultAccount: 'wechat_user_' + Math.floor(Math.random() * 10000)
                        },
                        qq: {
                            nickname: 'QQ用户',
                            defaultAccount: 'qq_user_' + Math.floor(Math.random() * 10000)
                        },
                        weibo: {
                            nickname: '微博用户',
                            defaultAccount: 'weibo_user_' + Math.floor(Math.random() * 10000)
                        }
                    };
                    
                    const userInfo = platformUserInfo[platform];
                    
                    if (needRegister) {
                        // 需要注册
                        resolve({
                            success: false,
                            needRegister: true,
                            thirdPartyInfo: {
                                platform: platform,
                                openId: 'mock_openid_' + platform + '_' + Date.now(),
                                nickname: userInfo.nickname,
                                account: accountInfo ? accountInfo.account : userInfo.defaultAccount
                            },
                            message: '检测到您是新用户，请完成注册'
                        });
                    } else {
                        // 直接登录成功
                        const username = accountInfo ? accountInfo.account : userInfo.defaultAccount;
                        resolve({
                            success: true,
                            token: 'mock_token_' + platform + '_' + Date.now(),
                            username: username,
                            userType: userType,
                            loginMethod: platform,
                            platform: platform
                        });
                    }
                }, 1500);
            });
        }

        // 显示提示消息
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            const toastMessage = document.getElementById('toastMessage');
            const toastIcon = document.getElementById('toastIcon');
            
            // 设置消息
            toastMessage.textContent = message;
            
            // 设置图标
            const icons = {
                success: '<i class="fa fa-check-circle text-green-500 text-xl"></i>',
                error: '<i class="fa fa-times-circle text-red-500 text-xl"></i>',
                warning: '<i class="fa fa-exclamation-circle text-yellow-500 text-xl"></i>',
                info: '<i class="fa fa-info-circle text-blue-500 text-xl"></i>'
            };
            toastIcon.innerHTML = icons[type] || icons.info;
            
            // 显示提示
            toast.classList.remove('hidden');
            
            // 自动隐藏
            setTimeout(() => {
                hideToast();
            }, 3000);
        }

        // 隐藏提示消息
        function hideToast() {
            document.getElementById('toast').classList.add('hidden');
        }

        // 更新首页导航栏
        function updateHomepageNavbar() {
            try {
                const navbarData = JSON.parse(localStorage.getItem('homepageNavbar') || 'null');
                if (navbarData) {
                    // 更新 Logo - 使用更宽泛的选择器
                    const logoImgs = document.querySelectorAll('header img[alt="圣举人才网"], header img[alt*="圣举"], header img[alt*="Logo"]');
                    logoImgs.forEach(logoImg => {
                        if (logoImg && navbarData.siteLogo) {
                            if (!logoImg.alt || logoImg.alt.includes('圣举') || logoImg.alt.includes('Logo')) {
                                logoImg.src = navbarData.siteLogo;
                            }
                        }
                    });
                    
                    // 更新网站名称
                    const siteNameEl = document.querySelector('header h1');
                    if (siteNameEl && navbarData.siteName) {
                        siteNameEl.textContent = navbarData.siteName;
                    }
                    
                    // 更新页面标题
                    if (navbarData.siteName) {
                        document.title = navbarData.siteName + ' - 测评驱动的招聘平台';
                    }
                }
            } catch (e) {
                console.error('更新首页导航栏失败:', e);
            }
        }
        
        // 页面加载时检查用户状态
        document.addEventListener('DOMContentLoaded', function() {
            checkUserAuth();
            // 确保页面加载时从systemSettings读取Logo（如果homepageNavbar没有数据）
            const homepageNavbar = JSON.parse(localStorage.getItem('homepageNavbar') || 'null');
            if (!homepageNavbar || !homepageNavbar.siteLogo) {
                const systemSettings = JSON.parse(localStorage.getItem('systemSettings') || '{}');
                if (systemSettings.siteLogo || systemSettings.siteName) {
                    // 同步systemSettings到homepageNavbar
                    const navbarData = {
                        siteName: systemSettings.siteName || '圣举人才网',
                        siteLogo: systemSettings.siteLogo || 'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22 viewBox=%220 0 40 40%22%3E%3Crect width=%2240%22 height=%2240%22 fill=%22%231E40AF%22 rx=%224%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-family=%22Arial, sans-serif%22 font-size=%2224%22 font-weight=%22bold%22 fill=%22white%22%3E圣%3C/text%3E%3C/svg%3E'
                    };
                    localStorage.setItem('homepageNavbar', JSON.stringify(navbarData));
                }
            }
            updateHomepageNavbar();
            
            // 检查是否有菜单切换按钮
            const menuToggle = document.getElementById('menu-toggle');
            if (menuToggle) {
                menuToggle.addEventListener('click', function() {
                    const mobileMenu = document.getElementById('mobile-menu');
                    if (mobileMenu) {
                        mobileMenu.classList.toggle('hidden');
                    }
                });
            }
        });
        
        // 监听设置更新事件
        window.addEventListener('homepageNavbarUpdated', function(event) {
            if (event.detail) {
                // 更新 Logo - 使用更宽泛的选择器
                const logoImgs = document.querySelectorAll('header img[alt="圣举人才网"], header img[alt*="圣举"], header img[alt*="Logo"]');
                logoImgs.forEach(logoImg => {
                    if (logoImg && event.detail.siteLogo) {
                        if (!logoImg.alt || logoImg.alt.includes('圣举') || logoImg.alt.includes('Logo')) {
                            logoImg.src = event.detail.siteLogo;
                        }
                    }
                });
                
                const siteNameEl = document.querySelector('header h1');
                if (siteNameEl && event.detail.siteName) {
                    siteNameEl.textContent = event.detail.siteName;
                }
                
                if (event.detail.siteName) {
                    document.title = event.detail.siteName + ' - 测评驱动的招聘平台';
                }
            }
        });
        
        // 监听 storage 事件（跨标签页同步）
        window.addEventListener('storage', function(event) {
            if (event.key === 'homepageNavbar') {
                updateHomepageNavbar();
            }
        });

        // ESC键关闭模态框
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeLoginModal();
                closeRegisterModal();
                closeThirdPartyModal();
                closeAdminLoginModal();
            }
        });
        
        // 检查URL参数，自动打开登录模态框
        document.addEventListener('DOMContentLoaded', function() {
            captureRegisterReturnFromUrl();
            const urlParams = new URLSearchParams(window.location.search);
            const action = urlParams.get('action');
            const userType = urlParams.get('userType');
            
            if (action === 'login') {
                setTimeout(() => {
                    openLoginModal();
                    if (userType) {
                        const userTypeRadio = document.querySelector(`input[name="userType"][value="${userType}"]`);
                        if (userTypeRadio) {
                            userTypeRadio.checked = true;
                            updateTestAccountHint();
                        }
                    }
                }, 100);
            } else if (action === 'register') {
                setTimeout(() => {
                    openRegisterModal();
                    if (userType) {
                        const regRadio = document.querySelector(`input[name="registerUserType"][value="${userType}"]`);
                        if (regRadio) regRadio.checked = true;
                        toggleRegisterVerifyBlock();
                    }
                }, 100);
            }
        });
    </script>
