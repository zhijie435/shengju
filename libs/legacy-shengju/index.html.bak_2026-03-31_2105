        // 检查用户登录状态（支持求职者与企业同时登录）
        function checkUserAuth() {
            var js = (typeof AuthHelper !== 'undefined') ? AuthHelper.get('jobseeker') : null;
            var ent = (typeof AuthHelper !== 'undefined') ? AuthHelper.get('enterprise') : null;
            if (!js && localStorage.getItem('userType') === 'jobseeker') {
                js = { token: localStorage.getItem('authToken'), username: localStorage.getItem('username'), userType: 'jobseeker' };
            }
            if (!ent && localStorage.getItem('userType') === 'enterprise') {
                ent = { token: localStorage.getItem('authToken'), username: localStorage.getItem('username'), userType: 'enterprise' };
            }
            var isAdmin = localStorage.getItem('userType') === 'admin' && localStorage.getItem('authToken');
            
            if (isAdmin || (js && js.token) || (ent && ent.token)) {
                document.getElementById('auth-buttons').classList.add('hidden');
                document.getElementById('user-info').classList.remove('hidden');
                document.getElementById('user-info').classList.add('flex');
                var welcomeText = document.getElementById('welcome-text');
                var usernameEl = document.getElementById('username');
                if (!welcomeText || !usernameEl) return;
                if (isAdmin) {
                    welcomeText.innerHTML = '欢迎，<span id="username" class="font-medium cursor-pointer hover:text-primary transition hover:underline" onclick="window.location.href=\'admin/index.html\'">' + (localStorage.getItem('username') || '管理员') + '</span>（点击进入管理端）';
                } else {
                    var parts = [];
                    if (js && js.token) parts.push('<a href="user/index.html" class="text-primary hover:underline">求职者：' + (js.username || '') + '</a>');
                    if (ent && ent.token) parts.push('<a href="enterprise/company-center.html" class="text-indigo-600 hover:underline">企业：' + (ent.username || '') + '</a>');
