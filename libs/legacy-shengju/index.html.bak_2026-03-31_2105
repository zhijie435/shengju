                if (typeof backendStatus !== 'undefined' && backendStatus.available && backendStatus.baseUrl) {
                    tip.classList.add('hidden');
                } else {
                    tip.classList.remove('hidden');
                }
            }
            updateRegisterTip();
            if (typeof backendStatus !== 'undefined' && !backendStatus.available) {
