    <script>
        // 全局错误处理 - 过滤Chrome内部错误
        window.addEventListener('error', function(event) {
            // 过滤Chrome内部错误（chrome-error://, chrome-extension://等）
            if (event.filename && (
                event.filename.includes('chrome-error://') ||
                event.filename.includes('chromewebdata') ||
                event.filename.includes('chrome-extension://') ||
                event.filename.startsWith('chrome://')
            )) {
                event.preventDefault();
                event.stopPropagation();
                return false;
            }
        }, true);
        
        // 过滤未捕获的Promise错误中的Chrome内部错误
        window.addEventListener('unhandledrejection', function(event) {
            if (event.reason && typeof event.reason === 'object') {
                const message = event.reason.message || event.reason.toString() || '';
                if (message.includes('chrome-error://') || 
                    message.includes('chromewebdata') ||
                    message.includes('chrome-extension://')) {
                    event.preventDefault();
                    return false;
                }
            }
        });
        
        // 测试账号配置（与 seed-mock-data.js 导入的账号一致，后端不可用时回退）
        const TEST_ACCOUNTS = {
