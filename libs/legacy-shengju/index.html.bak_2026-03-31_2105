    <!-- 登录模态框 -->
    <div id="loginModal" class="fixed inset-0 z-50 hidden">
        <div class="fixed inset-0 bg-black bg-opacity-50" onclick="closeLoginModal()"></div>
        <div class="fixed inset-0 flex items-center justify-center p-4">
            <div class="bg-white rounded-xl shadow-2xl max-w-md w-full max-h-[90vh] overflow-y-auto">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-bold text-primary">用户登录</h2>
                        <button onclick="closeLoginModal()" class="text-gray-400 hover:text-gray-600">
                            <i class="fa fa-times text-xl"></i>
                        </button>
                    </div>
                    
                    <form id="loginForm" onsubmit="handleLogin(event)">
                        <!-- 用户类型选择 -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">用户类型</label>
                            <div class="grid grid-cols-2 gap-3">
                                <label class="flex items-center justify-center p-3 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-primary transition">
                                    <input type="radio" name="userType" value="jobseeker" class="mr-2" checked>
                                    <i class="fa fa-user-circle mr-2 text-blue-500"></i>
                                    <span>求职者</span>
                                </label>
                                <label class="flex items-center justify-center p-3 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-primary transition">
                                    <input type="radio" name="userType" value="enterprise" class="mr-2">
                                    <i class="fa fa-building mr-2 text-indigo-500"></i>
                                    <span>企业用户</span>
                                </label>
                            </div>
                        </div>
                        
                        <!-- 邮箱/手机号 -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">邮箱/手机号</label>
                            <input type="text" id="loginIdentifier" required 
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                                   placeholder="请输入邮箱或手机号">
                        </div>
                        
                        <!-- 密码 -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">密码</label>
                            <div class="relative">
                                <input type="password" id="loginPassword" required 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                                       placeholder="请输入密码">
                                <button type="button" onclick="togglePassword('loginPassword')" 
                                        class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                    <i class="fa fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        
                        <!-- 测试账号提示 -->
                        <div id="testAccountHint" class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg hidden">
                            <p class="text-xs text-blue-800 font-medium mb-2">测试账号：</p>
                            <ul id="testAccountList" class="text-xs text-blue-700 space-y-1">
                            </ul>
                        </div>
                        
                        <!-- 记住我和忘记密码 -->
                        <div class="flex items-center justify-between mb-6">
                            <label class="flex items-center">
                                <input type="checkbox" class="mr-2">
                                <span class="text-sm text-gray-600">记住我</span>
                            </label>
                            <a href="#" class="text-sm text-primary hover:underline">忘记密码？</a>
                        </div>
                        
                        <!-- 登录按钮 -->
                        <button type="submit" 
                                class="w-full bg-primary hover:bg-blue-700 text-white font-medium py-3 rounded-lg transition">
                            登录
                        </button>
                        
                        <!-- 注册跳转 -->
                        <div class="text-center text-sm text-gray-600 mt-4">
                            <p>还没有账号？</p>
                            <button type="button" onclick="switchToRegisterFromLogin()" class="text-primary hover:underline font-medium">
                                立即注册
                            </button>
                        </div>
                        
                        <!-- 分割线 -->
                        <div class="flex items-center my-6">
                            <div class="flex-1 h-px bg-gray-300"></div>
                            <span class="px-4 text-sm text-gray-500">或</span>
                            <div class="flex-1 h-px bg-gray-300"></div>
                        </div>
                        
                        <!-- 第三方登录 -->
                        <div class="grid grid-cols-3 gap-3">
                            <button type="button" onclick="openThirdPartyLogin('wechat')" class="flex flex-col items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition group">
                                <i class="fa fa-weixin text-green-500 text-xl mb-1"></i>
                                <span class="text-xs text-gray-600 group-hover:text-green-500">微信</span>
                            </button>
                            <button type="button" onclick="openThirdPartyLogin('qq')" class="flex flex-col items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition group">
                                <i class="fa fa-qq text-blue-400 text-xl mb-1"></i>
                                <span class="text-xs text-gray-600 group-hover:text-blue-400">QQ</span>
                            </button>
                            <button type="button" onclick="openThirdPartyLogin('weibo')" class="flex flex-col items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition group">
                                <i class="fa fa-weibo text-red-500 text-xl mb-1"></i>
                                <span class="text-xs text-gray-600 group-hover:text-red-500">微博</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
