        // 注册成功后的跳转目标（由 URL ?return= 传入，如从公告页来注册后回公告）
        window.__postRegisterReturnUrl = null;
        var SJ_REGISTER_RETURN_KEY = 'sj_post_register_return';
        function normalizeRegisterReturn(raw) {
            if (!raw || typeof raw !== 'string') return null;
            var dec = raw.trim();
            // URLSearchParams.get 通常已解码一次；若仍含 %xx 再解一次（容错）
            try {
                if (dec.indexOf('%') >= 0) dec = decodeURIComponent(dec);
            } catch (e) { /* 保持 dec */ }
            if (dec.indexOf('://') >= 0 || dec.indexOf('javascript:') === 0) return null;
            if (dec.indexOf('//') === 0) return null;
            if (!/^[\w\-\.\/?&=%]+$/.test(dec)) return null;
            return dec;
        }
        function captureRegisterReturnFromUrl() {
            try {
                var params = new URLSearchParams(window.location.search);
                if (!params.has('return')) {
                    window.__postRegisterReturnUrl = null;
                    try { sessionStorage.removeItem(SJ_REGISTER_RETURN_KEY); } catch (e0) {}
                    return;
                }
                var raw = params.get('return');
                var dec = normalizeRegisterReturn(raw || '');
                if (dec) {
                    window.__postRegisterReturnUrl = dec;
                    try { sessionStorage.setItem(SJ_REGISTER_RETURN_KEY, dec); } catch (e2) {}
                }
            } catch (e) {}
        }
        function getRegisterReturnTarget() {
            var u = (typeof window.__postRegisterReturnUrl === 'string' && window.__postRegisterReturnUrl) ? window.__postRegisterReturnUrl : null;
            if (!u) {
