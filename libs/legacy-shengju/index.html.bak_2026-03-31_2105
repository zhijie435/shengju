        // API基础URL配置：仅当页面通过 http(s) 访问时才用当前来源，否则用本机默认，避免 file:// 打开时健康检查失败
        const BACKEND_BASE_URL = (function () {
            if (window.BACKEND_BASE_URL) return window.BACKEND_BASE_URL.replace(/\/$/, '');
            var origin = window.location && window.location.origin;
            if (origin && (origin.indexOf('http://') === 0 || origin.indexOf('https://') === 0)) {
