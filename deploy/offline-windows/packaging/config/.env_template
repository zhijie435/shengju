# ================================================================
# 圣举考试系统 - 离线本地配置
# 本文件由启动脚本自动生成，请勿手动修改路径相关配置
# ================================================================

NODE_ENV=production
PORT=3000
TRUST_PROXY=0

# 数据库（由随包 MariaDB 提供）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ShengjuLocal2024
MAIN_DB_NAME=question_management_shared
SHENGJU_DB_NAME=

# JWT（本地离线固定密钥，部署到公网时务必修改）
JWT_SECRET=offline-sjrcw-local-key-please-change-for-lan

# Puppeteer Chromium 路径（由启动脚本在 Node 进程环境变量中注入，此处备用）
PUPPETEER_EXECUTABLE_PATH=CHROMIUM_PATH_PLACEHOLDER
PUPPETEER_SKIP_DOWNLOAD=true

# 性能（单机/局域网场景，连接池缩小）
DB_POOL_SIZE=10
BODY_PARSER_LIMIT=80mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_PER_IP=1200

# ── 以下配置项留空 = 对应功能降级/关闭，不影响考试核心流程 ──────────────
# AI 评估报告（DeepSeek，需联网）
DEEPSEEK_API_KEY=

# 阿里云短信验证码（需联网）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 阿里云人脸 1:1 核验（需联网）
ALIYUN_VIAPI_ACCESS_KEY_ID=
ALIYUN_VIAPI_ACCESS_KEY_SECRET=

# 微信支付（需联网且需公网回调）
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_APIV3_KEY=
